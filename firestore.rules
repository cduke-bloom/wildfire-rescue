rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          'cduke@bloomtechsupport.com',
          'therealcodyduke@gmail.com'
        ];
    }

    function isAdmin() {
      return isSuperAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // -------- users --------
    match /users/{uid} {
      // public profile fields (display name, county, bio) readable by anyone
      // so that listings can show owner name even before the viewer signs in
      allow read: if true;
      // owner can create/update their own profile only
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // -------- listings --------
    match /listings/{id} {
      // listings are a public board — anyone can browse without signing in
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.active == true
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 120
                    && request.resource.data.details is string
                    && request.resource.data.details.size() <= 2000;

      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.ownerUid == request.auth.uid
                        && request.resource.data.ownerUid == resource.data.ownerUid
                        // Owner cannot change suspension fields
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['suspended', 'suspendedAt', 'suspendedBy',
                                     'suspendedReason'])
                        // Owner can only set approvalStatus to 'pending' (resubmit)
                        && (!('approvalStatus' in request.resource.data
                              .diff(resource.data).affectedKeys())
                            || request.resource.data.approvalStatus == 'pending')
                        // Owner cannot activate a listing that hasn't been approved
                        && (request.resource.data.active == false
                            || resource.data.get('approvalStatus', 'approved') == 'approved'));

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // -------- threads --------
    match /threads/{threadId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2;

      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants
                    // participants cannot be changed after creation
                    && !('participants' in
                        request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isSignedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;

        allow create: if isSignedIn()
                      && request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants
                      && request.resource.data.sender == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000;

        allow update: if false;
        allow delete: if false;
      }
    }

    // -------- admins --------
    // doc ID is the admin's lowercase email
    match /admins/{email} {
      // Each user can read their own admin doc to determine if they're an
      // admin. Existing admins can read all to see the list.
      allow read: if isAdmin()
                  || (isSignedIn() && email == request.auth.token.email);
      allow create: if isSuperAdmin()
                    && request.resource.data.email == email
                    && request.resource.data.addedBy is string;
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // -------- reports --------
    match /reports/{id} {
      allow create: if isSignedIn()
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 2000;
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
